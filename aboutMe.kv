ScrollView:
    do_scroll_x: False
    do_scroll_y: True


    Label:
        size_hint_y: None
        height: self.minimum_height             #This is the major line to trigger the Scroll
        text:
            "MY Mission\nI believe that financial peace of mind should'nt be a luxury" \
        "reserved for the few. MY mission is to bridge the gap between earning and building" \
        "wealth by creating systems that make saving automatic, intuitive and stress free" \
        "\nProblem Solved\nMost people don't have a 'spending' problem; they have a 'system' problem" \
        "Traditional banking makes it easy to pay others but incredely difficult to pay yourselves" \
        "I saw a world where hidden fees and complex interfaces were standing in the way of people's dreams" \
        "So I decided to build something better"

        text_size: self.size
        halign: 'left'
        font_size: 25
    
        