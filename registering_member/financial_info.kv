FinancialInfo
<FinancialInfo>:
    BoxLayout:
        orientation: 'vertical'
        spacing: 20
        

        Label:
            text: 'Registering as New Member'
            size_hint: 1,.15
            font_size: 35


        Label: 
            text: 'Step 4 of 4 Financial Information'
            font_size: 30
            size_hint: 1,.1
        

        GridLayout:
            cols: 2
            size_hint:.85,.7
            pos_hint: {'center_x': .5}
            spacing: 20


            Label: 
                text: 'Source of Income'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False



            Label: 
                text: 'Occupation'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False


            Label: 
                text: 'Monthly Income'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False
                


            Label: 
                text: 'Purpose of Saving'
                italic: True
                font_size: 25


            TextInput:
                font_size: 25
                text: 'optional'
                text_size: self.size
                halighn: 'center'
                multiline: False



            Label: 
                text: 'Other Saving Groups'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: True
                text: 'if any'
                italic: True

            Label: 
                text: 'Comment'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: True
            

        BoxLayout:
            spacing: 40
            size_hint: .6,.1
            pos_hint: {'center_y':.5,'center_x': .5}
            padding: 10


            Button:
                text: 'Back'
                font_size: 25
                bold: True
                on_release:
                    root.manager.current = 'accountinfo'
                    root.manager.transition.direction = 'down'           



            Button: 
                text: 'Next'
                font_size: 25
                bold: True
                on_release:
                    root.manager.current = 'login'
                    root.manager.transition.direction = 'left'
            



            





