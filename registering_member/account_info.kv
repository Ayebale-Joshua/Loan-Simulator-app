AccountInfo
<AccountInfo>:
    BoxLayout:
        orientation: 'vertical'
        spacing: 20
        

        Label:
            text: 'Registering as New Member'
            size_hint: 1,.15
            font_size: 35


        Label: 
            text: 'Step 3 of 4 Account Information'
            font_size: 30
            size_hint: 1,.1
        

        GridLayout:
            cols: 2
            size_hint:.85,.7
            pos_hint: {'center_x': .5}
            spacing: 20


            Label: 
                text: 'Account No'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False



            Label: 
                text: 'Date of Registration'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False


            Label: 
                text: 'Account Type'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False
                


            Label: 
                text: 'Initial Deposit'
                italic: True
                font_size: 25


            TextInput:
                font_size: 25
                text: 'optional'
                text_size: self.size
                halighn: 'center'
                multiline: False



            Label: 
                text: 'Group Name'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False

            Label: 
                text: 'Saving Method'
                font_size: 25


            TextInput:
                font_size: 25
                text_size: self.size
                halighn: 'center'
                multiline: False
            

        BoxLayout:
            spacing: 40
            size_hint: .6,.1
            pos_hint: {'center_y':.5,'center_x': .5}
            padding: 10


            Button:
                text: 'Back'
                font_size: 25
                bold: True
                on_release:
                    root.manager.current = 'contactinfo'
                    root.manager.transition.direction = 'down'
            



            Button: 
                text: 'Next'
                font_size: 25
                bold: True
                on_release:
                    root.manager.current = 'financialinfo'
                    root.manager.transition.direction = 'up'

            



            





